FROM golang:1.22-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /argus-sim ./cmd/argus-sim

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /argus-sim /usr/local/bin/argus-sim
COPY simulator/scenarios/ /scenarios/
ENTRYPOINT ["argus-sim"]
